{
  "name": "@mosadd/threat-engine",
  "version": "0.1.0",
  "description": "Deterministic threat scoring + severity/action primitives. Small and dependency-free — the shared severity/signal types the detection SDK builds on.",
  "keywords": [
    "threat",
    "scoring",
    "severity",
    "ai-safety",
    "deterministic"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "author": "mosADD",
  "homepage": "https://mosadd.com/voice-truthgate",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hei33enberg/voice-truthgate.git",
    "directory": "packages/threat-engine"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
