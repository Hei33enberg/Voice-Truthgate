{
  "name": "@mosadd/voice-analyzer-core",
  "version": "0.1.0-alpha.0",
  "description": "Deterministic, pure-TypeScript voice-deepfake feature extractor + heuristic scorer. No DOM, no Web Audio, no FFT library — runs identically in the browser, React Native, edge runtimes and Node.",
  "keywords": [
    "deepfake",
    "voice",
    "audio",
    "dsp",
    "feature-extraction",
    "heuristic",
    "on-device"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "author": "mosADD",
  "homepage": "https://mosadd.com/voicecheck",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hei33enberg/voicecheck.git",
    "directory": "packages/voice-analyzer-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
