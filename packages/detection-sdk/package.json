{
  "name": "@mosadd/detection-sdk",
  "version": "0.1.0-alpha.0",
  "description": "Pluggable detection pipeline — Detector / Signal / Verdict interfaces plus a fail-open runDetectors runner. The frame VoiceCheck's detectors plug into.",
  "keywords": [
    "detection",
    "pipeline",
    "ai-safety",
    "deepfake",
    "detector",
    "fail-open"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "author": "mosADD",
  "homepage": "https://mosadd.com/voicecheck",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hei33enberg/voicecheck.git",
    "directory": "packages/detection-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mosadd/threat-engine": "0.1.0"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
