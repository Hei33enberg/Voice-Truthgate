{
  "name": "@mosadd/voice-truthgate",
  "version": "0.1.0-alpha.0",
  "description": "Voice Truthgate by mosADD — honest, on-device voice-deepfake detection. On-device heuristic triage + an injectable server-confirmation detector, fused into a confidence BAND (never a bare verdict).",
  "keywords": [
    "deepfake",
    "deepfake-detection",
    "voice",
    "audio",
    "ai-safety",
    "on-device",
    "synthetic-speech",
    "voice-clone",
    "transformers-js"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "author": "mosADD",
  "homepage": "https://mosadd.com/voice-truthgate",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hei33enberg/voice-truthgate.git",
    "directory": "packages/voice-truthgate"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "MODEL_CARD.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mosadd/detection-sdk": "0.1.0-alpha.0",
    "@mosadd/voice-analyzer-core": "0.1.0-alpha.0",
    "@mosadd/threat-engine": "0.1.0"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
